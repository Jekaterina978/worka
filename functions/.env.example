# Copy this file to .env and fill in your values.
# .env is read automatically by Firebase CLI for local emulator.
# Never commit .env — it is in .gitignore.

# OpenAI secret key (required for /ai/parse-vacancy and /ai/parse-cv)
OPENAI_API_KEY=sk-...

# ── Production deployment ─────────────────────────────────────────────────────
# Option A — Google Cloud Run environment variable (simplest):
#   Set OPENAI_API_KEY in Cloud Console → Cloud Run → api service → Edit & Deploy
#
# Option B — Firebase Secret Manager (recommended):
#   1. firebase functions:secrets:set OPENAI_API_KEY
#   2. Add to exports.api in functions/index.js:
#        secrets: ['OPENAI_API_KEY'],
